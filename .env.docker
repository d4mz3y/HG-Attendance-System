# Used by Docker Compose (env_file). Host-native PHP: copy to .env and set DB_HOST=127.0.0.1, DB_PORT=3307.
APP_NAME="Hogan Guards Attendance"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost:8000

LOG_CHANNEL=stderr

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hg_attendance
DB_USERNAME=root
DB_PASSWORD=root

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
